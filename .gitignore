secrets.generated.txt
.env
.env.*
!.env.example
node_modules/
.DS_Store
.cursor/
.idea/

# Root-level generated/temp files
make_logo.py
manicbot_logo.png
.cursor-project-analysis-prompt.txt

# Generated static blog output (standalone `node generate.mjs` in manicbot-blog)
manicbot-blog/dist/
# wrangler local state
.wrangler
.dev.vars*
!.dev.vars.example

# Claude Code ephemeral worktrees (each is its own git repo — never commit as submodules)
.claude/worktrees/
.claude/settings.local.json

# IG/Meta tokens — never commit plaintext tokens
*.token
*-token-*.txt
ig-direct-token*
fb-page-token*
**/.config/manicbot/**

# Seed scripts with plaintext credentials — kept on developer machine only.
# A `.example` template (with `process.env.SEED_*_PASSWORD` placeholders) lives
# in the repo so anyone can reconstruct the structure without learning a real
# password. See manicbot/scripts/seed-web-users.example.mjs.
manicbot/scripts/seed-web-users.mjs
manicbot/scripts/seed-*-users.mjs
!manicbot/scripts/seed-*-users.example.mjs
