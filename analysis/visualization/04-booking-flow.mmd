stateDiagram-v2
    [*] --> idle : Пользователь начинает диалог

    state "Регистрация" as reg {
        idle --> REG_CONFIRM : Первый визит / нет телефона
        REG_CONFIRM --> REG_NAME : Подтверждает регистрацию
        REG_NAME --> REG_PHONE : Вводит имя
        REG_PHONE --> idle : Вводит телефон ✓
    }

    state "Выбор услуги" as svc {
        idle --> BOOK : [BOOK] команда или AI тег
        BOOK --> MASTER_PICK : Показать список мастеров
        BOOK --> DATE : Один мастер / "любой"
        MASTER_PICK --> DATE : Мастер выбран
    }

    state "Выбор даты и времени" as dt {
        DATE --> TIME : Дата выбрана
        TIME --> CONFIRM : Время выбрано
    }

    state "Подтверждение" as conf {
        CONFIRM --> pending : Клиент подтверждает ✓
        CONFIRM --> BOOK_ADJUST : Клиент хочет изменить
        BOOK_ADJUST --> DATE : Новая дата
        BOOK_ADJUST --> MASTER_PICK : Другой мастер
    }

    state "Жизненный цикл записи" as lifecycle {
        state pending {
            [*] --> awaiting_admin : Ожидает подтверждения

            awaiting_admin --> confirmed : Админ/мастер подтвердил ✓
            awaiting_admin --> rejected : Админ/мастер отклонил ✗
            awaiting_admin --> counter_offered : Предложено другое время

            state counter_offered {
                [*] --> counter_time : Админ вводит время
                counter_time --> counter_comment : Вводит комментарий
                counter_comment --> [*] : Отправлено клиенту
            }

            counter_offered --> confirmed : Клиент принял
            counter_offered --> rejected : Клиент отказался
        }

        confirmed --> cancelled_client : Клиент отменил
        confirmed --> cancelled_admin : Админ отменил

        state cancelled_client {
            [*] --> cancel_reason : Клиент указывает причину
        }

        state cancelled_admin {
            [*] --> admin_cancel_reason : Админ указывает причину
        }

        rejected --> [*] : Запись закрыта
        cancelled_client --> [*] : Запись отменена
        cancelled_admin --> [*] : Запись отменена
    }

    state "Побочные эффекты" as effects {
        state fork_state <<fork>>
        confirmed --> fork_state

        fork_state --> notify_client : Уведомление клиенту
        fork_state --> notify_master : Уведомление мастеру
        fork_state --> google_sync : Google Calendar Event
        fork_state --> reminder_24h : Cron: напоминание за 24ч
        fork_state --> reminder_2h : Cron: напоминание за 2ч
    }
