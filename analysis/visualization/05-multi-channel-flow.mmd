flowchart LR
    subgraph Input["Входящие каналы"]
        TG_IN["Telegram<br/>POST /webhook/:botId"]
        WA_IN["WhatsApp<br/>POST /webhook/wa"]
        IG_IN["Instagram<br/>POST /webhook/ig"]
    end

    subgraph Verify["Верификация"]
        TG_V["Telegram<br/>WEBHOOK_SECRET<br/>timing-safe compare"]
        WA_V["WhatsApp<br/>HMAC-SHA256<br/>META_APP_SECRET"]
        IG_V["Instagram<br/>HMAC-SHA256<br/>META_APP_SECRET"]
    end

    subgraph Resolve["Резолвинг тенанта"]
        TG_R["D1: bots.bot_id<br/>→ tenant_id"]
        WA_R["D1: channel_configs<br/>phone_number_id → tenant_id"]
        IG_R["D1: channel_configs<br/>page_id → tenant_id"]
    end

    subgraph Normalize["Нормализация (inbound.js)"]
        NORM["InboundMessage<br/>channel, channelUserId,<br/>text, contact, callbackData"]
        WINDOW["updateMessageWindow()<br/>24ч окно для WA/IG"]
        IDENTITY["upsertChannelIdentity()<br/>Связь: channel_user → internal_user"]
        CONV["upsertConversation()<br/>Unified inbox metadata"]
    end

    subgraph Core["Ядро обработки"]
        MSG["onMsg(ctx, msg)<br/>handlers/message.js"]
        CB["onCb(ctx, cb)<br/>handlers/callback.js"]
        AI["AI Chat<br/>ai.js → Workers AI"]
        STATE["Стейт-машина<br/>services/state.js"]
        APT["Бронирование<br/>services/appointments.js"]
    end

    subgraph Output["Адаптеры отправки"]
        TG_OUT["channels/telegram.js<br/>Bot API: send, edit"]
        WA_OUT["channels/whatsapp.js<br/>Graph API + Templates"]
        IG_OUT["channels/instagram.js<br/>Graph API: Page token"]
    end

    subgraph ButtonLogic["Логика кнопок"]
        TG_BTN["Telegram<br/>Inline keyboard<br/>Без ограничений"]
        WA_BTN["WhatsApp<br/>1-3: reply buttons<br/>4-10: list<br/>>10: paginated"]
        IG_BTN["Instagram<br/>1-3: quick replies<br/>4-13: persistent menu"]
    end

    TG_IN --> TG_V --> TG_R
    WA_IN --> WA_V --> WA_R
    IG_IN --> IG_V --> IG_R

    TG_R -->|"buildTenantCtx()"| MSG
    TG_R -->|"buildTenantCtx()"| CB

    WA_R --> NORM
    IG_R --> NORM

    NORM --> WINDOW
    NORM --> IDENTITY
    NORM --> CONV
    NORM -->|"_inboundToMsg()"| MSG
    NORM -->|"_inboundToCb()"| CB

    MSG --> AI
    MSG --> STATE
    MSG --> APT
    CB --> STATE
    CB --> APT

    MSG -->|"ctx.channel.send()"| TG_OUT
    MSG -->|"ctx.channel.send()"| WA_OUT
    MSG -->|"ctx.channel.send()"| IG_OUT

    TG_OUT --> TG_BTN
    WA_OUT --> WA_BTN
    IG_OUT --> IG_BTN

    classDef telegram fill:#0088cc,stroke:#006699,color:#fff
    classDef whatsapp fill:#25d366,stroke:#128c7e,color:#fff
    classDef instagram fill:#e4405f,stroke:#c13584,color:#fff
    classDef core fill:#6366f1,stroke:#4f46e5,color:#fff

    class TG_IN,TG_V,TG_R,TG_OUT,TG_BTN telegram
    class WA_IN,WA_V,WA_R,WA_OUT,WA_BTN whatsapp
    class IG_IN,IG_V,IG_R,IG_OUT,IG_BTN instagram
    class MSG,CB,AI,STATE,APT core
