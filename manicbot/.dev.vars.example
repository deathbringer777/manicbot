# ─── manicbot Worker — Local Development Variables ───────────────────────────
# Скопируй в .dev.vars и подставь свои значения.
# .dev.vars gitignored — НИКОГДА не коммить реальные секреты.
# wrangler dev читает .dev.vars автоматически.
# Для production: wrangler secret put <NAME>
#
# ─── CRON OPERATIONAL FLAGS (optional) ───────────────────────────────────────
# ATTACHMENT_GC_DELETE=1   # enable the destructive R2 sweep of orphaned messenger
#                          # attachments (default: dry-run — logs candidates only).
#                          # Read the dry-run logs first (event cron.attachment_gc.dryrun);
#                          # go-live + rollback steps: docs/runbooks/attachment-gc.md

# ─── ОБЯЗАТЕЛЬНЫЕ ────────────────────────────────────────────────────────────

# Telegram chat_id создателя — даёт God Mode (полный доступ к платформе)
# Узнай через @userinfobot в Telegram
ADMIN_CHAT_ID=123456789

# Admin API key — защищает маршруты /admin/* (длинная случайная строка)
ADMIN_KEY=your_random_admin_key_here

# Stripe billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_START_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_MAX_MONTHLY=price_...
# Annual pricing (optional — leave unset if not offering annual plans)
# STRIPE_PRICE_START_ANNUAL=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_MAX_ANNUAL=price_...

# Cloudflare Workers AI (для LLM-чата)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
WORKERS_AI_API_TOKEN=your_workers_ai_api_token

# ─── ОПЦИОНАЛЬНЫЕ ────────────────────────────────────────────────────────────

# Шифрование токенов IG/WA в D1/KV (ОБЯЗАТЕЛЬНО для Meta-каналов в production)
# Должен быть установлен ДО провижн Meta-канала
# BOT_ENCRYPTION_KEY=32_или_более_случайных_символов
# Previous encryption key — set only during key rotation; unset after rotate completes
# BOT_ENCRYPTION_KEY_OLD=previous_key_value

# Meta (WhatsApp / Instagram) webhooks
# META_APP_SECRET=your_meta_app_secret
# META_INSTAGRAM_APP_SECRET=your_instagram_login_app_secret
# META_VERIFY_TOKEN_WA=your_whatsapp_verify_token
# META_VERIFY_TOKEN_IG=your_instagram_verify_token

# Meta OAuth — connect Instagram via the in-product UI (no manual token paste).
# META_APP_ID is the FB Login for Business app id (already public, in [vars]).
# META_INSTAGRAM_APP_ID is the Instagram Login product app id (separate from
# the FB app id — Meta moved IG messaging onto its own product in Mar-2026).
# Both secrets must be set for the corresponding OAuth provider to be offered;
# missing values → /meta/oauth/start returns 503 (oauth_not_configured).
# META_INSTAGRAM_APP_ID=3756985564432185

# Meta Conversions API (server-side ad-tracking → dataset "ManicBot Web").
# META_CAPI_PIXEL_ID is the public dataset/Pixel id (lives in wrangler.toml [vars]).
# META_CAPI_TOKEN is the secret (Events Manager → dataset → Settings → Conversions
# API → Generate access token). Both required, else CAPI no-ops. Optional test code
# routes events to Events Manager "Test events" instead of live.
# META_CAPI_TOKEN=EAA...your_capi_access_token
# META_CAPI_TEST_EVENT_CODE=TEST12345

# Instagram: IGSID через запятую — игнорировать (например аккаунт самого бота)
# INSTAGRAM_IGNORE_SENDER_IDS=1784360123456789

# ─── NOTIFICATIONS / INTERNAL ────────────────────────────────────────────────

# Low-privilege notify-only Bearer token for POST /admin/notify (min 32 chars)
# NOTIFY_TOKEN=your_notify_only_token_min_32_chars

# ─── SYSTEM & SEASONAL MESSAGING ─────────────────────────────────────────────
# Global real-send gate. "0" (default) STAGES every reactive/seasonal delivery
# (ledger 'skipped_flag', zero egress). Flip to "1" after reviewing templates.
# Declared in wrangler.toml [vars]; override here for local dev if needed.
# MESSAGING_SEND_ENABLED=0
# Low-privilege Bearer token for the ThinkPad → /admin/messaging/* seam (min 32
# chars). Can ONLY touch messaging tables. Set in prod via wrangler secret put.
# MESSAGING_TOKEN=your_messaging_seam_token_min_32_chars

# Telegram bot token for internal admin notifications (defaults to BOT_TOKEN)
# NOTIFY_BOT_TOKEN=123456:ABCdef...

# Telegram chat_id for admin notifications (defaults to ADMIN_CHAT_ID)
# NOTIFY_CHAT_ID=123456789

# ─── ADMIN / OPS BOT (interactive monitoring; system_admin only) ─────────────
# Turns the notify bot into a two-way AI ops/monitoring bot. Reaches /webhook/{botId}
# via the existing pipeline; owner-only (gated by ADMIN_CHAT_ID).
#   - Bot token resolution: ADMIN_BOT_TOKEN → (ADMIN_USE_BOT_TOKEN=1 ? BOT_TOKEN) → NOTIFY_BOT_TOKEN.
#   - REQUIRED to enable: ADMIN_WEBHOOK_SECRET (min 16 chars). Without it the bot
#     is disabled (getCtx will not intercept the botId).
# After setting these, register the webhook once: GET /admin/register-admin-bot-webhook
# (Bearer ADMIN_KEY). Hijack guard: refuses a registered client bot ONLY on the
# accidental NOTIFY_BOT_TOKEN fallback; an EXPLICIT ADMIN_BOT_TOKEN / ADMIN_USE_BOT_TOKEN
# is a deliberate repurpose and is allowed (that bot's tenant Telegram flow stops).
# ADMIN_BOT_TOKEN=123456:ABCdef...            # optional; dedicated admin bot
# ADMIN_USE_BOT_TOKEN=1                        # optional; reuse the Worker's BOT_TOKEN (the 7:20 report bot) — no token to paste
# ADMIN_WEBHOOK_SECRET=min_16_char_secret_here
# ADMIN_BOT_ALLOWED_IDS=123456789 987654321   # optional extra authorized Telegram user ids

# Shared Bearer secret between Worker and admin-app for internal endpoints
# (e.g. /admin/confirm-subscription). Must match admin-app INTERNAL_API_TOKEN.
# INTERNAL_API_TOKEN=your_internal_api_token

# HMAC-SHA256 secret for upload token signing. Must match admin-app UPLOAD_TOKEN_SECRET.
# UPLOAD_TOKEN_SECRET=your_upload_token_secret

# HMAC secret for WebSocket upgrade tokens (/ws/messenger/{tenantId}).
# Must match admin-app WS_TOKEN_SECRET.
# WS_TOKEN_SECRET=your_ws_token_secret

# ─── EMAIL ────────────────────────────────────────────────────────────────────

# Resend transactional email
# RESEND_API_KEY=re_...
# RESEND_FROM=ManicBot <noreply@manicbot.com>

# ─── MARKETING — click tracking & conversions (migration 0123) ────────────────
# HMAC secret signing the /r/<token> click-redirect links in campaign emails.
# Same value MUST be set on BOTH the Worker and the admin-app (Pages). Without
# it, link rewriting is skipped (emails still send; clicks/conversions stay 0).
# CLICK_TOKEN_SECRET=min_32_char_random_secret
# Set to "0" to disable link rewriting without unsetting the secret.
# CLICK_TRACKING_ENABLED=1
# Worker origin used to build /r/ and /u/ links (defaults to https://manicbot.com).
# WORKER_PUBLIC_URL=https://manicbot.com

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────

# Anthropic Claude API key — used by marketing caption generator
# ANTHROPIC_API_KEY=sk-ant-...

# ─── MARKETING ────────────────────────────────────────────────────────────────

# Facebook Page ID + token for IG marketing autopilot posting
# MARKETING_IG_PAGE_ID=your_page_id
# MARKETING_IG_ACCESS_TOKEN=your_page_access_token

# ─── ADVANCED / DEVOPS ────────────────────────────────────────────────────────

# Webhook deduplication backend: "kv" (default), "d1", or "none"
# WEBHOOK_DEDUP_BACKEND=kv

# Dev-only bypass for BOT_ENCRYPTION_KEY requirement — NEVER set in production
# ALLOW_PLAINTEXT_TOKENS=1

# Google OAuth (для интеграции Google Calendar)
# Code reads GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET (not GOOGLE_CLIENT_ID/SECRET)
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REDIRECT_URI=https://manicbot.com/google/callback
# GOOGLE_TOKEN_ENCRYPTION_KEY=32_or_more_random_chars  # dedicated key; falls back to BOT_ENCRYPTION_KEY

# Отклонять legacy POST /webhook (без botId) — только D1 мультиарендный режим
# REQUIRE_WEBHOOK_BOT_ID=1

# Включить legacy single-bot ctx fallback (P2-3). По умолчанию выключен.
# Только для миграции/тестов; на production оставляйте unset — иначе env BOT_TOKEN
# обходит D1 + шифрование. При включении worker логирует [SECURITY] warning.
# ALLOW_LEGACY_BOT_CTX=1

# ─── LEGACY (одиночный бот) ──────────────────────────────────────────────────
# Нужны только при использовании POST /webhook без botId И ALLOW_LEGACY_BOT_CTX=1
# BOT_TOKEN=123456:ABCdef...
# WEBHOOK_SECRET=your_webhook_secret
