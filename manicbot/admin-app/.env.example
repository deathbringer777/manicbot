# ManicBot admin-app — local development environment
#
# 1. Copy this file to `.env` (it is gitignored).
# 2. Populate placeholders below; leave commented lines in place if unused.
# 3. The schema in `src/env.js` is the source of truth — when you add a new
#    var, also add it to that schema so t3-env validates it at startup.
# 4. Production values live in the Cloudflare Pages dashboard:
#    Settings → Environment variables → Production. Do NOT commit them here.

# ── Required ────────────────────────────────────────────────────────────────

# NextAuth signing secret — 64-char hex. Generate with: `openssl rand -hex 32`
# Rotation runbook: manicbot/SECRET_ROTATION.md
AUTH_SECRET=""

# Telegram bot token used for the dashboard's notify hook (NOT the per-tenant
# salon bot — that lives in D1 `bots.token_encrypted`).
TELEGRAM_BOT_TOKEN="test_token"

# Cloudflare D1 — local LibSQL file for `npm run dev` (production uses D1 binding).
DATABASE_URL="file:./db.sqlite"

# ── Strongly recommended ────────────────────────────────────────────────────

# system_admin / God Mode chat ID. Same value as Worker secret.
ADMIN_CHAT_ID=""

# Worker ADMIN_KEY — used by admin-app to call internal Worker endpoints
# (appointment-action, etc). Same value as Worker secret.
ADMIN_KEY=""

# AES-GCM master key for bot-token encryption (#H3). Same value as Worker
# `BOT_ENCRYPTION_KEY` secret. Required for `connectBot` mutation; if unset
# the mutation refuses to register a bot rather than write a NULL token.
BOT_ENCRYPTION_KEY=""

# Public origin for links inside transactional emails (Resend). REQUIRED in
# production so reset/verification links resolve to the correct domain.
AUTH_URL="http://localhost:3000"

# Resend transactional email
# RESEND_API_KEY="re_..."
# RESEND_FROM="ManicBot <noreply@yourdomain.com>"

# ── Optional integrations ───────────────────────────────────────────────────

# Cloudflare Worker public URL (used to display webhook hints in Mini App)
# WORKER_PUBLIC_URL="https://manicbot.com"

# Messenger realtime: shared HMAC secret for signing short-lived WS
# upgrade tokens. Must be set BOTH here AND on the Worker (same value)
# for /ws/messenger/{tenantId} to verify. Recommended: 32+ random bytes.
# WS_TOKEN_SECRET=""

# Shared upload-token secret (must match Worker UPLOAD_TOKEN_SECRET)
# UPLOAD_TOKEN_SECRET=""

# Meta verification tokens (must match Worker secrets of same name)
# META_VERIFY_TOKEN_WA=""
# META_VERIFY_TOKEN_IG=""

# Google OAuth (login + Google Calendar)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Stripe billing (mirror Worker secrets)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRICE_START_MONTHLY="price_..."
# STRIPE_PRICE_PRO_MONTHLY="price_..."
# STRIPE_PRICE_MAX_MONTHLY="price_..."
# STRIPE_PRICE_START_ANNUAL="price_..."
# STRIPE_PRICE_PRO_ANNUAL="price_..."
# STRIPE_PRICE_MAX_ANNUAL="price_..."

# Stripe publishable key (client-side; safe to expose)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Worker .dev.vars also needs matching secrets — see manicbot/.dev.vars.example
