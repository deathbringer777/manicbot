# @cloudflare/next-on-pages@1.13.16 caps peer to next<=15.5.2, but the
# security advisory range is next<=15.5.14 — we must run 15.5.15+.
# Vercel CLI (invoked by next-on-pages during the Pages build) runs a fresh
# `npm install` and honors this file, letting us ignore the stale peer range.
legacy-peer-deps=true
# Supply-chain hardening (Semgrep npm-missing-minimum-release-age, gating CI):
# wait 7 days before resolving a newly-published package version, so a freshly
# compromised release can't slip into a build. Harmless with a complete
# package-lock.json (locked versions are already pinned; this only constrains
# range resolution) and ignored by npm < 11.10.
min-release-age=7
