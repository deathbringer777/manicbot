# @cloudflare/next-on-pages@1.13.16 caps peer to next<=15.5.2, but the
# security advisory range is next<=15.5.14 — we must run 15.5.15+.
# Vercel CLI (invoked by next-on-pages during the Pages build) runs a fresh
# `npm install` and honors this file, letting us ignore the stale peer range.
legacy-peer-deps=true

# Supply-chain cooldown (npm v11.10+): refuse to resolve package versions
# published less than 7 days ago, so a freshly-compromised release isn't pulled
# into the Pages build before it's caught and yanked. Satisfies Semgrep
# package_managers.npm.npm-missing-minimum-release-age. With the committed
# lockfile, in-sync installs reuse already-pinned (older) versions unaffected.
min-release-age=7
