# ManicBot messaging ThinkPad tier — copy to .env (gitignored, chmod 600) on the server.
# The repo is PUBLIC: NEVER commit real values.

# Worker base URL (prod apex).
WORKER_URL=https://manicbot.com

# Low-privilege Bearer for the /admin/messaging/* seam. Matches the Worker secret
# set via `wrangler secret put MESSAGING_TOKEN`. Min 32 random chars.
MESSAGING_TOKEN=

# Optional: where the approved-facts docs live for the preset generator.
# Defaults to ./_shared (scp PRODUCT.md + BRAND.md there — they are gitignored).
# MESSAGING_SHARED_DIR=/home/kirill/automation/messaging/_shared

# Optional: content-plan look-ahead window in days (default 35).
# MESSAGING_LOOKAHEAD_DAYS=35
