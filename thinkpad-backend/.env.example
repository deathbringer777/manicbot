# ~/manicbot-backend/.env — copy to the server, never commit the real one.

# ManicBot Worker (health checks + /admin/notify fallback)
WORKER_URL=https://manicbot.com
# Low-privilege notify-only token for the Worker /admin/notify route
NOTIFY_TOKEN=

# Telegram (rich notifications with buttons go straight to the Bot API).
# Same bot token the tg-bot uses; CHAT_ID = the owner chat.
TELEGRAM_TOKEN=
CHAT_ID=

# Cloudflare D1 (nightly backup + blog publish). Scoped token: D1 read/write ONLY.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Google Search Console monitor (gsc-monitor cron). Until this is set the cron
# no-ops. Create a Google service account, enable the Search Console API, add
# the service-account email as a user on the GSC property, then paste its JSON
# key here (single line) — OR set GOOGLE_APPLICATION_CREDENTIALS to a file path.
GSC_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=sc-domain:manicbot.com

# OPTIONAL — lead-scout "google" source via the Programmable Search (Custom
# Search JSON) API. Both must be set for it to return results; otherwise the
# google source is a graceful no-op. Free tier: 100 queries/day.
#   key:  https://developers.google.com/custom-search/v1/overview
#   cx:   https://programmablesearchengine.google.com/  (search-engine id)
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# NOTE: no ANTHROPIC_API_KEY here on purpose. All LLM calls go through the
# `claude` CLI which is OAuth-bound to the Max subscription (~/.claude).
