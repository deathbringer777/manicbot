# tg-bot .env — lives only on the server, never in git.

TELEGRAM_TOKEN=your_telegram_bot_token
ALLOWED_USER_ID=your_telegram_user_id
CHAT_ID=your_chat_id

# Voice notes only (Groq Whisper STT — Claude does no speech-to-text)
GROQ_KEY=gsk_your_groq_api_key
# WHISPER_MODEL=whisper-large-v3-turbo

# Text LLM = claude CLI on the Max subscription (OAuth in ~/.claude).
# No API keys needed; optional overrides:
# CLAUDE_BIN=claude
# CLAUDE_MODEL=sonnet
# CLAUDE_EFFORT=medium
# CLAUDE_TIMEOUT_MS=300000
